# Copy this to .env and fill in your values

# Required: Anthropic API key for Claude scoring
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Google Drive credentials
# Set to path of either:
#   - OAuth client secrets JSON (credentials.json from Google Cloud Console)
#   - Service account key JSON
# If not set, Drive upload is skipped; data is saved locally only.
GOOGLE_DRIVE_CREDENTIALS_FILE=

# Current monetary policy cycle regime (analyst updates this)
# Values: tightening | holding | easing
CYCLE_REGIME=holding
